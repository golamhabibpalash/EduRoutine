# EduRoutine Backend — environment template (copy to .env)
# All values are read by src/shared/config/settings.py (Pydantic Settings).

# --- Application ---
APP_NAME=EduRoutine
APP_ENV=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Database (PostgreSQL, async driver) ---
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql+asyncpg://eduroutine:eduroutine@localhost:5432/eduroutine
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Redis (reserved for Phase 1+; refresh tokens / cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT (base auth only — NO social login in Phase 1) ---
# RS256 keys are loaded from PEM files in later phases; HS256 secret used for dev bootstrap.
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-value
JWT_ISSUER=eduroutine-api
JWT_AUDIENCE=eduroutine-client
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:3000
